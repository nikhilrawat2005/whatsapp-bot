# Flask Server configurations
PORT=5000
FLASK_ENV=development
SECRET_KEY=production-session-secret-key-string-here
SESSION_SECRET=production-additional-session-secret-string-here

# Database connection URL
# Default fallback to SQLite: sqlite:///hospital.db if DATABASE_URL is not set
DATABASE_URL=postgresql://user:password@localhost:5432/dbname

# Hospital Settings
HOSPITAL_NAME="ABC Hospital"
HOSPITAL_PHONE="+1 (234) 567-8900"
HOSPITAL_EMAIL="support@abchospital.com"
HOSPITAL_ADDRESS="123 Health Avenue, Medical District"

